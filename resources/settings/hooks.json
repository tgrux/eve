{
  "_comment": "Optional hooks configuration following Claude Code hooks schema: https://code.claude.com/docs/en/hooks",
  "_schema": {
    "hook_key": {
      "name": "Display name",
      "description": "Description for interactive selection",
      "hooks": {
        "HookEventName": [
          {
            "matcher": "optional regex pattern",
            "hooks": [
              {
                "type": "command|prompt|agent",
                "command": "shell command for type: command",
                "prompt": "prompt text for type: prompt|agent",
                "timeout": "optional timeout in seconds",
                "async": "optional boolean for background execution (command only)"
              }
            ]
          }
        ]
      }
    }
  },
  "typescript_checks": {
    "name": "TypeScript Type Checking",
    "description": "Run tsc type checking after editing TypeScript files",
    "hooks": {
      "PostToolUse": [
        {
          "matcher": "Write|Edit",
          "hooks": [
            {
              "type": "command",
              "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tsc-slim.js"
            }
          ]
        }
      ]
    }
  },
  "eslint_checks": {
    "name": "ESLint Linting",
    "description": "Run ESLint after editing JS/TS files",
    "hooks": {
      "PostToolUse": [
        {
          "matcher": "Write|Edit",
          "hooks": [
            {
              "type": "command",
              "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/eslint-hook.js"
            }
          ]
        }
      ]
    }
  }
}
